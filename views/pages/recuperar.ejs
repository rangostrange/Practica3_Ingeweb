<link rel="stylesheet" href="/css/formStyles.css">
<form action="/recuperar" method="POST">

  <input type="hidden" name="accion" value="pregunta" id="accion">

  <label>Correo:</label>
  <input type="email" name="correo" value="<%= correo || '' %>" required>

  <% if (pregunta) { %>

    <label>Pregunta:</label>
    <input type="text" value="<%= pregunta %>" readonly>

    <label>Respuesta:</label>
    <input type="text" name="respuesta" required>

    <label>Nueva contraseña:</label>
    <input type="password" name="nuevaContrasena" required>

    <script>
      document.getElementById("accion").value = "reset";
    </script>

  <% } %>

  <button type="submit">
    <%= pregunta ? "Cambiar contraseña" : "Continuar" %>
  </button>

</form>

<% if (error) { %>
  <p style="color:red;"><%= error %></p>
<% } %>